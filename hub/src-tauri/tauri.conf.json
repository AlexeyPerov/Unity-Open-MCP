{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unity Hub Pro",
  "version": "0.7.0",
  "identifier": "com.alexeyperov.unity-hub-pro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Unity Hub Pro",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 12, "y": 16 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Unity Hub Pro — manage and launch Unity projects. In CLI mode, pass -projectPath to launch a project and exit without opening the Hub window.",
      "args": [
        {
          "name": "projectPath",
          "short": "p",
          "description": "Open the Unity project at <path> with the matching installed Unity version and exit.",
          "index": 1,
          "takesValue": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
