{
  "id": "m9-reserialize-prefab-extension",
  "title": "Reserialize round-trips a .prefab asset",
  "milestone": "m9",
  "engineId": "unity",
  "order": 100,
  "requirementLevel": "optional",
  "tags": ["m9", "reserialize", "extension-matrix", "plan-1"],
  "automatedCoverage": [
    "ReserializeAssetsToolTests.SupportedExtensions_IncludesAllRequiredFormats"
  ],
  "steps": [
    {
      "id": "info",
      "type": "info",
      "title": "Prerequisites",
      "body": "Bridge running. Optional extension-matrix check (automated-covered): confirm `.prefab` is accepted and round-tripped by `unity_open_mcp_reserialize`. The supported-extension surface itself is asserted by the automated test below; this scenario is a runnable confidence pass."
    },
    {
      "id": "setup-fixture",
      "type": "setup",
      "title": "Stage a non-canonical copy of a prefab",
      "actions": [
        {
          "action": "fs_copy",
          "from": "Assets/Fixtures/HealthyFixture.prefab",
          "to": "{fixtureRoot}/ExtPrefab.prefab"
        },
        {
          "action": "fs_patch",
          "path": "{fixtureRoot}/ExtPrefab.prefab",
          "patches": [
            {
              "op": "insert_after_line_contains",
              "match": "  m_Name: HealthyFixture",
              "insert": "  m_TagString: Untagged "
            }
          ]
        }
      ]
    },
    {
      "id": "prompt",
      "type": "agent_prompt",
      "title": "Run reserialize on the .prefab",
      "tool": "unity_open_mcp_reserialize",
      "payload": {
        "paths": ["{fixtureRoot}/ExtPrefab.prefab"],
        "gate": "enforce"
      }
    },
    {
      "id": "expected",
      "type": "expected",
      "title": "Expected outcomes",
      "items": [
        "mutation.success is true (extension accepted)",
        "mutation.output.reserialized contains the .prefab path; totalCount: 1",
        "gate.validation.passed is true",
        "file on disk is canonical Unity YAML"
      ]
    },
    {
      "id": "actual",
      "type": "actual",
      "title": "Paste the agent output (raw envelope)"
    },
    {
      "id": "done",
      "type": "mark_done",
      "title": "Mark this test complete"
    }
  ],
  "reset": {
    "afterStep": {
      "setup-fixture": {
        "actions": [{ "action": "fs_delete", "paths": ["{fixtureRoot}"] }]
      }
    },
    "note": "Optional, automated-covered scenario. The supported-extension contract is asserted by ReserializeAssetsToolTests; this runnable pass is for operator confidence against a live asset."
  }
}
