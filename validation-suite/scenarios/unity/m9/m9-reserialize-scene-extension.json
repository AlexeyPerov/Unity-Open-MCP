{
  "id": "m9-reserialize-scene-extension",
  "title": "Reserialize round-trips a .unity scene asset",
  "milestone": "m9",
  "engineId": "unity",
  "order": 101,
  "requirementLevel": "optional",
  "tags": ["m9", "reserialize", "extension-matrix", "plan-1"],
  "automatedCoverage": [
    "ReserializeAssetsToolTests.SupportedExtensions_IncludesAllRequiredFormats"
  ],
  "steps": [
    {
      "id": "info",
      "type": "info",
      "title": "Prerequisites",
      "body": "Bridge running. Optional extension-matrix check (automated-covered): confirm `.unity` is accepted and round-tripped. The supported-extension surface is asserted by the automated test; this is a runnable confidence pass against a live scene."
    },
    {
      "id": "setup-fixture",
      "type": "setup",
      "title": "Stage a non-canonical copy of a scene",
      "actions": [
        {
          "action": "fs_copy",
          "from": "Assets/Scenes/Main.unity",
          "to": "{fixtureRoot}/ExtScene.unity"
        },
        {
          "action": "fs_patch",
          "path": "{fixtureRoot}/ExtScene.unity",
          "patches": [
            {
              "op": "trim_trailing_whitespace"
            }
          ]
        }
      ]
    },
    {
      "id": "prompt",
      "type": "agent_prompt",
      "title": "Run reserialize on the .unity scene",
      "tool": "unity_open_mcp_reserialize",
      "payload": {
        "paths": ["{fixtureRoot}/ExtScene.unity"],
        "gate": "enforce"
      }
    },
    {
      "id": "expected",
      "type": "expected",
      "title": "Expected outcomes",
      "items": [
        "mutation.success is true (extension accepted)",
        "mutation.output.reserialized contains the .unity path; totalCount: 1",
        "gate.validation.passed is true",
        "file on disk is canonical Unity YAML"
      ]
    },
    {
      "id": "actual",
      "type": "actual",
      "title": "Paste the agent output (raw envelope)"
    },
    {
      "id": "done",
      "type": "mark_done",
      "title": "Mark this test complete"
    }
  ],
  "reset": {
    "afterStep": {
      "setup-fixture": {
        "actions": [{ "action": "fs_delete", "paths": ["{fixtureRoot}"] }]
      }
    },
    "note": "Optional, automated-covered scenario. The supported-extension contract is asserted by ReserializeAssetsToolTests; this runnable pass is for operator confidence against a live scene."
  }
}
